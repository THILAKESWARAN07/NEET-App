ENVIRONMENT=production
PROJECT_NAME=NEET Prep App
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/neet_app
SECRET_KEY=replace-with-very-strong-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
VERIFY_GOOGLE_TOKEN=true
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
ADMIN_EMAIL=your_email@gmail.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
STORAGE_BASE_URL=https://storage.example.com
STORAGE_PROVIDER=s3
STORAGE_BUCKET_NAME=your-bucket-name
STORAGE_REGION=your-region
STORAGE_ENDPOINT_URL=
STORAGE_OBJECT_PREFIX=neet-app
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
